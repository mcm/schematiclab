{
  "name": "schematiclab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:translations": "node --experimental-strip-types scripts/generate-block-translations.mts && node --experimental-strip-types scripts/generate-forge-1.12-flatten.mts",
    "gen:mc-assets": "node --experimental-strip-types scripts/build-minecraft-assets.mts",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@iamthemcmaster/ui": "^0.3.0",
    "@tabler/icons-react": "^3.40.0",
    "deepslate": "^0.26.0",
    "fflate": "^0.8.3",
    "gl-matrix": "^3.4.4",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
